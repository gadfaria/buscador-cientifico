# --- Fontes ---
BDTD_API_BASE=https://bdtd.ibict.br/vufind/api/v1
CAPES_CKAN_BASE=https://dadosabertos.capes.gov.br/api/3/action

# resource_ids do Catálogo de Teses e Dissertações no CKAN da CAPES.
# Cada período é um resource separado; liste os que quiser federar (CSV).
# Preencher após inspecionar o portal (package_search no CKAN).
CAPES_RESOURCE_IDS=

# --- Cache ---
REDIS_URL=redis://localhost:6379
# TTL do cache de respostas, em segundos.
CACHE_TTL_SECONDS=900

# --- Federação ---
# Timeout por fonte (ms). A busca não espera além disso por uma fonte lenta.
SOURCE_TIMEOUT_MS=4000
